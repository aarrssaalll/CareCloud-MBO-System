generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// MBO System Models - Using prefixed table names to avoid conflicts

model MboUser {
  id          String   @id @default(cuid())
  employeeId  String?  @unique
  email       String   @unique
  firstName   String?
  lastName    String?
  name        String   // Full name for compatibility
  role        String   // EMPLOYEE, MANAGER, HR, SENIOR_MANAGEMENT
  title       String?
  phone       String?
  hireDate    DateTime?
  salary      Float?
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE, TERMINATED
  permissions String?  // JSON array of permissions
  profileImage String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Organizational hierarchy
  departmentId String?
  department   MboDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  teamId       String?
  team         MboTeam?       @relation(fields: [teamId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  managerId    String?
  manager      MboUser?       @relation("ManagerEmployee", fields: [managerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  directReports MboUser[]     @relation("ManagerEmployee")
  
  objectives       MboObjective[]
  reviews          MboReview[]
  bonuses          MboBonus[]
  objectiveReviews MboObjectiveReview[] @relation("ReviewerRelation")
  assignedObjectives MboObjective[] @relation("AssignedBy")
  approvals        MboApproval[]
  
  @@map("mbo_users")
}

model MboObjective {
  id          String        @id @default(cuid())
  title       String
  description String
  category    String
  target      Float
  current     Float
  weight      Float         @default(1.0)
  status      String        @default("ACTIVE") // ACTIVE, COMPLETED, ON_HOLD, CANCELLED
  dueDate     DateTime
  quarter     String
  year        Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  userId      String
  user        MboUser       @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  assignedById String?
  assignedBy   MboUser?     @relation("AssignedBy", fields: [assignedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  reviews     MboObjectiveReview[]
  
  @@map("mbo_objectives")
}

model MboObjectiveReview {
  id           String   @id @default(cuid())
  score        Float
  comments     String?
  reviewDate   DateTime @default(now())
  
  objectiveId  String
  objective    MboObjective @relation(fields: [objectiveId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  reviewerId   String
  reviewer     MboUser   @relation("ReviewerRelation", fields: [reviewerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  @@map("mbo_objective_reviews")
}

model MboReview {
  id              String      @id @default(cuid())
  quarter         String
  year            Int
  overallScore    Float
  comments        String?
  status          String      @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, REJECTED
  submittedAt     DateTime?
  approvedAt      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  employeeId      String
  employee        MboUser     @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  @@map("mbo_reviews")
}

model MboBonus {
  id            String   @id @default(cuid())
  quarter       String
  year          Int
  baseAmount    Float
  performanceMultiplier Float
  finalAmount   Float
  status        String   @default("CALCULATED") // CALCULATED, APPROVED, PAID, REJECTED
  calculatedAt  DateTime @default(now())
  paidAt        DateTime?
  
  employeeId    String
  employee      MboUser  @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  @@map("mbo_bonuses")
}

model MboDepartment {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  budget      Float?
  managerId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  users       MboUser[]
  teams       MboTeam[]
  
  @@map("mbo_departments")
}

model MboTeam {
  id           String   @id @default(cuid())
  name         String
  description  String?
  leaderId     String?
  departmentId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  department   MboDepartment @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users        MboUser[]
  
  @@map("mbo_teams")
}

model MboApproval {
  id          String   @id @default(cuid())
  type        String   // REVIEW, BONUS, OBJECTIVE
  entityId    String   // ID of the entity being approved
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  comments    String?
  approvedAt  DateTime?
  rejectedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  approverId  String
  approver    MboUser  @relation(fields: [approverId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  @@map("mbo_approvals")
}
