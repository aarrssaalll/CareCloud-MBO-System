generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model MboDepartment {
  id          String    @id @default(cuid()) @db.NVarChar(36)
  name        String    @db.NVarChar(255)
  description String?   @db.NVarChar(Max)
  budget      Float?
  managerId   String?   @db.NVarChar(36)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  teams       MboTeam[]
  users       MboUser[]
  manager     MboUser?  @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("mbo_departments")
}

model MboTeam {
  id           String        @id @default(cuid()) @db.NVarChar(36)
  name         String        @db.NVarChar(255)
  description  String?       @db.NVarChar(Max)
  departmentId String        @db.NVarChar(36)
  leaderId     String?       @db.NVarChar(36)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  department   MboDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  leader       MboUser?      @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users        MboUser[]

  @@map("mbo_teams")
}

model MboUser {
  id                    String               @id @default(cuid()) @db.NVarChar(36)
  employeeId            String?              @unique @db.NVarChar(50)
  email                 String               @unique @db.NVarChar(255)
  firstName             String?              @db.NVarChar(255)
  lastName              String?              @db.NVarChar(255)
  name                  String               @db.NVarChar(255)
  role                  String               @db.NVarChar(50)
  title                 String?              @db.NVarChar(255)
  phone                 String?              @db.NVarChar(50)
  hireDate              DateTime?
  salary                Float?
  bonusAmount           Float?               @default(0) // Cumulative total of all bonuses received over time
  allocatedBonusAmount  Float?               @default(0) // Annual bonus allocation based on hierarchy (1000-5000)
  password              String?              @db.NVarChar(255)
  departmentId          String?              @db.NVarChar(36)
  teamId                String?              @db.NVarChar(36)
  managerId             String?              @db.NVarChar(36)
  permissions           String?              @db.NVarChar(Max)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  
  // Relations
  department            MboDepartment?       @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  team                  MboTeam?             @relation(fields: [teamId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  manager               MboUser?             @relation("UserManager", fields: [managerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  // Reverse relations
  managedUsers          MboUser[]            @relation("UserManager")
  managedDepartments    MboDepartment[]      @relation("DepartmentManager")
  ledTeams              MboTeam[]            @relation("TeamLeader")
  objectives            MboObjective[]       @relation("UserObjectives")
  assignedObjectives    MboObjective[]       @relation("AssignedByUser")
  managerObjectives     MboManagerObjective[] @relation("ManagerObjectives")
  assignedManagerObjectives MboManagerObjective[] @relation("AssignedManagerObjectives")
  bonuses               MboBonus[]
  objectiveReviews      MboObjectiveReview[] @relation("ReviewerRelation")
  reviews               MboReview[]
  approvals             MboApproval[]
  notifications         MboNotification[]

  @@map("mbo_users")
}

model MboObjective {
  id           String               @id @default(cuid()) @db.NVarChar(36)
  title        String               @db.NVarChar(255)
  description  String?              @db.NVarChar(Max)
  category     String?              @db.NVarChar(100)
  target       Float
  current      Float?               @default(0)
  weight       Float?               @default(1.0)
  status       String?              @default("DRAFT") @db.NVarChar(50)  // DRAFT, ACTIVE, COMPLETED, AI_SCORED, REVIEWED, SUBMITTED_TO_HR, HR_APPROVED
  dueDate      DateTime
  quarter      String               @db.NVarChar(10)
  year         Int
  submittedAt  DateTime?
  completedAt  DateTime?
  submittedToManagerAt DateTime?
  managerReviewedAt    DateTime?
  submittedToHrAt      DateTime?
  hrApprovedAt         DateTime?
  employeeRemarks      String?      @db.NVarChar(Max)
  managerFeedback      String?      @db.NVarChar(Max)
  hrNotes              String?      @db.NVarChar(Max)
  aiScoreMetadata      String?      @db.NVarChar(Max)
  digitalSignature     String?      @db.NVarChar(Max)
  isQuantitative       Boolean              @default(false)
  objectiveType        String?              @db.NVarChar(50)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  userId       String               @db.NVarChar(36)
  assignedById String?              @db.NVarChar(36)
  
  reviews      MboObjectiveReview[]
  quantitativeData MboQuantitativeEmployeeObjective?
  user         MboUser              @relation("UserObjectives", fields: [userId], references: [id], onDelete: Cascade)
  assignedBy   MboUser?             @relation("AssignedByUser", fields: [assignedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@map("mbo_objectives")
}

model MboObjectiveReview {
  id          String       @id @default(cuid()) @db.NVarChar(36)
  score       Float
  comments    String?      @db.NVarChar(Max)
  reviewDate  DateTime?    @default(now())
  reviewType  String?      @default("MANAGER") @db.NVarChar(50) // MANAGER, HR, FINAL
  aiScore     Float?
  aiComments  String?      @db.NVarChar(Max)
  manualOverride Boolean?   @default(false)
  objectiveId String       @db.NVarChar(36)
  reviewerId  String       @db.NVarChar(36)
  objective   MboObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  reviewer    MboUser      @relation("ReviewerRelation", fields: [reviewerId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([objectiveId])
  @@index([reviewerId])
  @@map("mbo_objective_reviews")
}

model MboReview {
  id           String    @id @default(cuid()) @db.NVarChar(36)
  quarter      String    @db.NVarChar(10)
  year         Int
  overallScore Float?
  comments     String?   @db.NVarChar(Max)
  status       String?   @default("DRAFT") @db.NVarChar(50)
  submittedAt  DateTime?
  approvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  employeeId   String    @db.NVarChar(36)
  employee     MboUser   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("mbo_reviews")
}

model MboBonus {
  id                    String    @id @default(cuid()) @db.NVarChar(36)
  quarter               String    @db.NVarChar(10)
  year                  Int
  baseAmount            Float
  performanceMultiplier Float
  finalAmount           Float
  status                String?   @default("CALCULATED") @db.NVarChar(50)
  calculatedAt          DateTime? @default(now())
  paidAt                DateTime?
  employeeId            String    @db.NVarChar(36)
  employee              MboUser   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("mbo_bonuses")
}

model MboApproval {
  id          String    @id @default(cuid()) @db.NVarChar(36)
  type        String    @db.NVarChar(50)
  entityId    String    @db.NVarChar(36)
  status      String    @default("PENDING") @db.NVarChar(50)
  comments    String?   @db.NVarChar(Max)
  approverId  String    @db.NVarChar(36)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  approvedAt  DateTime?
  approver    MboUser   @relation(fields: [approverId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([approverId])
  @@index([entityId])
  @@map("mbo_approvals")
}

model MboManagerObjective {
  id                          String    @id @default(cuid()) @db.NVarChar(36)
  title                       String    @db.NVarChar(255)
  description                 String?   @db.NVarChar(Max)
  category                    String?   @db.NVarChar(100)
  target                      Float
  current                     Float?    @default(0)
  weight                      Float?    @default(1.0)
  status                      String?   @default("ASSIGNED") @db.NVarChar(50) // ASSIGNED, IN_PROGRESS, COMPLETED, MANAGER_SUBMITTED, AI_SCORED, SENIOR_REVIEWED, SUBMITTED_TO_HR, HR_APPROVED
  dueDate                     DateTime
  quarter                     String    @db.NVarChar(10)
  year                        Int
  
  // Workflow timestamps
  assignedAt                  DateTime  @default(now())
  startedAt                   DateTime?
  completedAt                 DateTime?
  managerSubmittedAt          DateTime?
  aiScoredAt                  DateTime?
  seniorReviewedAt            DateTime?
  submittedToHrAt             DateTime?
  hrApprovedAt                DateTime?
  
  // Manager submission data
  managerRemarks              String?   @db.NVarChar(Max)
  managerEvidence             String?   @db.NVarChar(Max)
  managerDigitalSignature     String?   @db.NVarChar(Max)
  
  // AI scoring data
  aiScore                     Float?
  aiComments                  String?   @db.NVarChar(Max)
  aiScoringMetadata           String?   @db.NVarChar(Max)
  
  // Senior management review data
  seniorManagerScore          Float?
  seniorManagerComments       String?   @db.NVarChar(Max)
  finalScore                  Float?
  seniorDigitalSignature      String?   @db.NVarChar(Max)
  
  // HR data
  hrNotes                     String?   @db.NVarChar(Max)
  bonusAmount                 Float?
  
  // Objective type fields
  isQuantitative              Boolean   @default(false)
  objectiveType               String?   @db.NVarChar(50)
  
  // Audit fields
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
  
  // Foreign keys
  managerId                   String    @db.NVarChar(36)
  assignedBySeniorManagerId   String    @db.NVarChar(36)
  
  // Relations
  manager                     MboUser   @relation("ManagerObjectives", fields: [managerId], references: [id], onDelete: Cascade)
  assignedBySeniorManager     MboUser   @relation("AssignedManagerObjectives", fields: [assignedBySeniorManagerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  quantitativeData            MboQuantitativeObjective?

  @@index([managerId])
  @@index([assignedBySeniorManagerId])
  @@index([status])
  @@index([quarter, year])
  @@index([dueDate])
  @@map("mbo_manager_objectives")
}

model MboQuantitativeObjective {
  id                    String              @id @default(cuid()) @db.NVarChar(36)
  managerObjectiveId    String              @unique @db.NVarChar(36)
  totalTargetRevenue    Float
  totalAchievedRevenue  Float               @default(0)
  overallProgress       Float               @default(0)
  currency              String              @default("USD") @db.NVarChar(10)
  trackingStartDate     DateTime            @default(now())
  lastUpdatedAt         DateTime            @updatedAt
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  
  // Relations
  managerObjective      MboManagerObjective @relation(fields: [managerObjectiveId], references: [id], onDelete: Cascade)
  practiceRevenues      MboPracticeRevenue[]

  @@index([managerObjectiveId])
  @@map("mbo_quantitative_objectives")
}

model MboQuantitativeEmployeeObjective {
  id                       String                    @id @default(cuid()) @db.NVarChar(36)
  employeeObjectiveId      String                    @unique @db.NVarChar(36)
  totalTargetRevenue       Float
  totalAchievedRevenue     Float                     @default(0)
  overallProgress          Float                     @default(0)
  currency                 String                    @default("USD") @db.NVarChar(10)
  trackingStartDate        DateTime                  @default(now())
  lastUpdatedAt            DateTime                  @updatedAt
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  
  // Relations
  employeeObjective        MboObjective              @relation(fields: [employeeObjectiveId], references: [id], onDelete: Cascade)
  practiceRevenues         MboEmployeePracticeRevenue[]

  @@index([employeeObjectiveId])
  @@map("mbo_quantitative_employee_objectives")
}

model MboPracticeRevenue {
  id                        String                   @id @default(cuid()) @db.NVarChar(36)
  quantitativeObjectiveId   String                   @db.NVarChar(36)
  practiceName              String                   @db.NVarChar(255)
  practiceCode              String?                  @db.NVarChar(50)
  targetRevenue             Float
  achievedRevenue           Float                    @default(0)
  progressPercentage        Float                    @default(0)
  weight                    Float                    @default(1.0)
  status                    String                   @default("ACTIVE") @db.NVarChar(50)
  notes                     String?                  @db.NVarChar(Max)
  
  // Versioning and tracking
  version                   Int                      @default(1)
  isCurrent                 Boolean                  @default(true)
  isSnapshot                Boolean                  @default(false)
  updateType                String                   @default("MANUAL") @db.NVarChar(50)
  previousAchievedRevenue   Float?
  revenueDelta              Float?
  
  // Audit fields
  recordedBy                String?                  @db.NVarChar(255)
  recordedAt                DateTime                 @default(now())
  remarks                   String?                  @db.NVarChar(Max)
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  
  // Relations
  quantitativeObjective     MboQuantitativeObjective @relation(fields: [quantitativeObjectiveId], references: [id], onDelete: Cascade)

  @@index([quantitativeObjectiveId])
  @@map("mbo_practice_revenues")
}

model MboEmployeePracticeRevenue {
  id                               String                           @id @default(cuid()) @db.NVarChar(36)
  quantitativeEmployeeObjectiveId  String                           @db.NVarChar(36)
  practiceName                     String                           @db.NVarChar(255)
  practiceCode                     String?                          @db.NVarChar(50)
  targetRevenue                    Float
  achievedRevenue                  Float                            @default(0)
  progressPercentage               Float                            @default(0)
  weight                           Float                            @default(1.0)
  status                           String                           @default("ACTIVE") @db.NVarChar(50)
  notes                            String?                          @db.NVarChar(Max)
  
  // Versioning and tracking
  version                          Int                              @default(1)
  isCurrent                        Boolean                          @default(true)
  isSnapshot                       Boolean                          @default(false)
  updateType                       String                           @default("MANUAL") @db.NVarChar(50)
  previousAchievedRevenue          Float?
  revenueDelta                     Float?
  
  // Audit fields
  recordedBy                       String?                          @db.NVarChar(255)
  recordedAt                       DateTime                         @default(now())
  remarks                          String?                          @db.NVarChar(Max)
  createdAt                        DateTime                         @default(now())
  updatedAt                        DateTime                         @updatedAt
  
  // Relations
  quantitativeEmployeeObjective    MboQuantitativeEmployeeObjective @relation(fields: [quantitativeEmployeeObjectiveId], references: [id], onDelete: Cascade)

  @@index([quantitativeEmployeeObjectiveId])
  @@map("mbo_employee_practice_revenues")
}

model MboNotification {
  id        String   @id @default(cuid()) @db.NVarChar(36)
  type      String   @db.NVarChar(50) // 'info', 'warning', 'success', 'error'
  title     String   @db.NVarChar(255)
  message   String   @db.NVarChar(Max)
  read      Boolean  @default(false)
  actionRequired Boolean @default(false)
  entityId  String?  @db.NVarChar(36) // Related objective, review, etc.
  entityType String? @db.NVarChar(50) // 'objective', 'review', 'bonus'
  createdAt DateTime @default(now())
  userId    String   @db.NVarChar(36)
  user      MboUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@map("mbo_notifications")
}
